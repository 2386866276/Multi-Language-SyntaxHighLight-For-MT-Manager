{
    name: ["CSS", ".css"],
    ignoreCase: true,

    styles: [
        "funcName"       #009999 #66e6ff,   // 用于 @规则名称、自定义属性等
        "operator"       #00009c #abc9ff,
        "member"         #0066ad #bce0ff,   // 属性名
        "method"         #0039e6 #57b3ff,
        "annotation"     #cc5e00 #ffb373,   // @规则关键字、!important
        "nodeReference"  #2e8c00 #63c259,
        "comment"        #141414 #dddddd,
        "docComment"     #282666 #99b3cc,
        "identifier"     #000000 #ffffff,
        "string"         #996b00 #ffeda1,
        "keyword"        #e62282 #ff7085,   // 标签选择器、函数关键字
        "contorKeyword"  #bd1fcc #ff8ccc,   // 伪类/伪元素
        "number"         #008c47 #a1ffe0,
        "type"           #009933 #42ffc2,   // 类选择器、属性值
        "critical"       #cc2424 #c45959,
        "warning"        #bf6308 #b89c7a,   // ID 选择器
        "notice"         #3d8a17 #8fab82,
        "placeholder"    #ed9954 #ffbf66    // 字符串转义
    ],

    bracketPairs: ["{}", "[]", "()"],

    defines: [
        // HTML 标签选择器
        "htmlTags": keywordsToRegex(
            "html body head title meta link script style"
            "div span section article aside nav header footer main figure figcaption"
            "h1 h2 h3 h4 h5 h6 p blockquote pre code kbd samp var"
            "a abbr b i strong em small mark del ins sub sup"
            "ul ol li dl dt dd"
            "table thead tbody tfoot tr th td caption colgroup col"
            "form input button select option optgroup textarea label fieldset legend"
            "img picture source video audio track canvas svg"
            "iframe embed object param"
            "address time progress meter details summary dialog"
        ),

        // CSS 属性名
        "propertyNames": keywordsToRegex(
            // 布局相关
            "display position top right bottom left float clear"
            "width height min-width min-height max-width max-height"
            "margin margin-top margin-right margin-bottom margin-left"
            "padding padding-top padding-right padding-bottom padding-left"
            "box-sizing overflow overflow-x overflow-y"
            "z-index visibility opacity"

            // Flexbox
            "flex flex-direction flex-wrap flex-flow flex-grow flex-shrink flex-basis"
            "justify-content align-items align-self align-content"
            "order gap row-gap column-gap"

            // Grid
            "grid grid-template grid-template-rows grid-template-columns grid-template-areas"
            "grid-auto-rows grid-auto-columns grid-auto-flow"
            "grid-row grid-row-start grid-row-end"
            "grid-column grid-column-start grid-column-end"
            "grid-area place-items place-content place-self"

            // 文本相关
            "color font font-family font-size font-weight font-style font-variant"
            "line-height letter-spacing word-spacing text-align text-decoration"
            "text-indent text-transform text-shadow text-overflow"
            "white-space word-break word-wrap overflow-wrap hyphens"
            "direction unicode-bidi writing-mode vertical-align"

            // 背景相关
            "background background-color background-image background-repeat"
            "background-position background-position-x background-position-y"
            "background-size background-attachment background-origin background-clip"
            "background-blend-mode"

            // 边框相关
            "border border-width border-style border-color border-radius"
            "border-top border-right border-bottom border-left"
            "border-top-width border-right-width border-bottom-width border-left-width"
            "border-top-style border-right-style border-bottom-style border-left-style"
            "border-top-color border-right-color border-bottom-color border-left-color"
            "border-top-left-radius border-top-right-radius"
            "border-bottom-left-radius border-bottom-right-radius"
            "border-image border-image-source border-image-slice"
            "border-image-width border-image-outset border-image-repeat"
            "outline outline-width outline-style outline-color outline-offset"
            "box-shadow"

            // 列表相关
            "list-style list-style-type list-style-position list-style-image"

            // 表格相关
            "border-collapse border-spacing caption-side empty-cells table-layout"

            // 变换和动画
            "transform transform-origin transform-style perspective perspective-origin"
            "backface-visibility"
            "transition transition-property transition-duration transition-timing-function transition-delay"
            "animation animation-name animation-duration animation-timing-function"
            "animation-delay animation-iteration-count animation-direction"
            "animation-fill-mode animation-play-state"

            // 滤镜和混合
            "filter backdrop-filter mix-blend-mode isolation"

            // 其他
            "cursor pointer-events resize user-select appearance"
            "content quotes counter-reset counter-increment"
            "clip clip-path mask mask-image mask-size mask-repeat mask-position"
            "object-fit object-position"
            "scroll-behavior scroll-snap-type scroll-snap-align"
            "will-change contain"

            // 旧版和供应商前缀（常见的）
            "zoom accelerator behavior ime-mode"
            "scrollbar-width scrollbar-color"
            "scrollbar-base-color scrollbar-face-color scrollbar-track-color"
            "scrollbar-arrow-color scrollbar-shadow-color"
            "scrollbar-highlight-color scrollbar-3d-light-color scrollbar-dark-shadow-color"
            "text-align-last text-justify text-kashida-space text-autospace"
            "text-underline-position word-break line-break"
            "ruby-align ruby-overhang ruby-position"
            "layout-flow layout-grid layout-grid-char layout-grid-line layout-grid-mode layout-grid-type"
            "layout-grid-char-spacing include-source layer-background-color layer-background-image"
            "page page-break-before page-break-after page-break-inside"
            "marks orphans widows"
            "size volume stress richness"
            "speak speak-header speak-numeral speak-punctuation speech-rate"
            "voice-family pitch pitch-range elevation azimuth"
            "play-during pause pause-before pause-after cue cue-before cue-after"
        ),

        // CSS 属性值（关键字）
        "propertyValues": keywordsToRegex(
            // 通用值
            "inherit initial unset revert auto none"

            // display
            "block inline inline-block inline-table table table-row table-cell"
            "flex inline-flex grid inline-grid"
            "flow-root contents list-item run-in"

            // position
            "static relative absolute fixed sticky"

            // float/clear
            "left right both"

            // overflow
            "visible hidden scroll clip"

            // 颜色关键字
            "transparent currentcolor"
            "black white gray silver"
            "red green blue yellow cyan magenta"
            "maroon navy olive purple teal fuchsia lime aqua orange"

            // font-weight
            "normal bold bolder lighter"

            // font-style
            "italic oblique"

            // font-variant
            "small-caps"

            // text-align
            "center justify"

            // text-decoration
            "underline overline line-through blink"

            // text-transform
            "uppercase lowercase capitalize"

            // white-space
            "nowrap pre pre-wrap pre-line break-spaces"

            // word-break
            "break-all keep-all break-word"

            // vertical-align
            "baseline top middle bottom sub super text-top text-bottom"

            // background-repeat
            "repeat repeat-x repeat-y no-repeat space round"

            // background-attachment
            "scroll fixed local"

            // background-size
            "cover contain"

            // background-origin/clip
            "border-box padding-box content-box"

            // border-style
            "solid dashed dotted double groove ridge inset outset"

            // list-style-type
            "disc circle square decimal decimal-leading-zero"
            "lower-roman upper-roman lower-alpha upper-alpha"
            "lower-greek lower-latin upper-latin armenian georgian"

            // list-style-position
            "inside outside"

            // cursor
            "pointer default move text wait help crosshair progress"
            "not-allowed no-drop grab grabbing zoom-in zoom-out"
            "e-resize ne-resize nw-resize n-resize se-resize sw-resize s-resize w-resize"
            "ew-resize ns-resize nesw-resize nwse-resize col-resize row-resize all-scroll"

            // pointer-events
            "all"

            // resize
            "horizontal vertical"

            // user-select
            "text all"

            // justify-content/align-items/align-content
            "flex-start flex-end center space-between space-around space-evenly stretch"
            "start end"

            // flex-direction
            "row row-reverse column column-reverse"

            // flex-wrap
            "wrap wrap-reverse"

            // align-self
            "self-start self-end"

            // grid-auto-flow
            "dense"

            // transform-style
            "flat preserve-3d"

            // backface-visibility
            "visible hidden"

            // animation-direction
            "reverse alternate alternate-reverse"

            // animation-fill-mode
            "forwards backwards"

            // animation-play-state
            "running paused"

            // animation-iteration-count
            "infinite"

            // timing functions
            "ease ease-in ease-out ease-in-out linear step-start step-end"

            // mix-blend-mode
            "multiply screen overlay darken lighten color-dodge color-burn"
            "hard-light soft-light difference exclusion hue saturation color luminosity"

            // box-sizing
            "border-box content-box"

            // object-fit
            "fill contain cover scale-down"

            // 旧版值
            "above below higher lower show hide open-quote close-quote no-open-quote no-close-quote"
            "leftwards rightwards far-left far-right left-side right-side behind"
            "x-slow slow medium fast x-fast faster slower"
            "x-soft soft loud x-loud silent spell-out digits continuous once"
            "xx-small x-small small large x-large xx-small smaller larger"
            "ultra-condensed extra-condensed condensed semi-condensed"
            "semi-expanded expanded extra-expanded ultra-expanded"
            "wider narrower"
            "ltr rtl bidi-override embed isolate isolate-override plaintext"
            "separate collapse avoid always page column"
            "print screen tv tty projection handheld braille embossed aural speech"
            "landscape portrait format mix"
            "menu message-box small-caption status-bar"
            "serif sans-serif monospace cursive fantasy"
            "caption icon small-caption"
            "male female child code"
            "spell-out"
        ),

        // 字符串
        "strings": [
            {
                start: {match: /"/},
                end: {match: /(?m)"|$/},
                style: "string",
                contains: [
                    {match: /\\./, 0: "placeholder"}
                ]
            },
            {
                start: {match: /'/},
                end: {match: /(?m)'|$/},
                style: "string",
                contains: [
                    {match: /\\./, 0: "placeholder"}
                ]
            }
        ],

        // 数字和单位
        "numbers": [
            // 十六进制颜色
            {match: /#([0-9a-fA-F]{3,8})\b/, 0: "parseColor(auto,1,HEX)"},

            // 数字 + 百分号
            {match: /\b\d+(\.\d+)?%/, 0: "number"},

            // 数字 + 单位
            {match: /\b\d+(\.\d+)?(ch|cm|deg|dpcm|dpi|dppx|em|ex|fr|grad|hz|in|khz|mm|ms|pc|pt|px|q|rad|rem|s|turn|vh|vmax|vmin|vw)\b/, 0: "number"},

            // 纯数字
            {match: /\b\d+(\.\d+)?\b/, 0: "number"}
        ],

        // url() 函数
        "urlFunction": {
            start: {match: /\b(url)\s*\(/, 1: "keyword"},
            end: {match: /\)|$/},
            contains: [
                {include: "strings"},
                {match: /[^\s)]+/, 0: "string"}
            ]
        },

        // var() 函数（高亮 CSS 变量）
        "varFunction": {
            start: {match: /\b(var)\s*\(/, 1: "keyword"},
            end: {match: /\)|$/},
            contains: [
                {match: /--[\w-]+/, 0: "member"},      // 自定义属性名
                {match: /,/, 0: "operator"},
                {include: "strings"},
                {include: "numbers"},
                {match: include("propertyValues"), 0: "type"}
            ]
        },

        // 其他 CSS 函数
        "functions": {
            start: {match: /\b(calc|rgb|rgba|hsl|hsla|hwb|lab|lch|oklab|oklch|color|linear-gradient|radial-gradient|repeating-linear-gradient|repeating-radial-gradient|conic-gradient|repeating-conic-gradient|min|max|clamp|attr|counter|counters|cubic-bezier|steps|translate|translateX|translateY|translateZ|translate3d|scale|scaleX|scaleY|scaleZ|scale3d|rotate|rotateX|rotateY|rotateZ|rotate3d|skew|skewX|skewY|matrix|matrix3d|perspective|blur|brightness|contrast|drop-shadow|grayscale|hue-rotate|invert|opacity|saturate|sepia)\s*\(/, 1: "keyword"},
            end: {match: /\)|$/},
            contains: [
                {include: "strings"},
                {include: "numbers"},
                {match: include("propertyValues"), 0: "type"},
                {match: /\//, 0: "operator"},
                {match: /,/, 0: "operator"}
            ]
        },

        // @media 中的特征查询
        "mediaFeatures": [
            {
                start: {match: /\(/},
                end: {match: /\)/},
                contains: [
                    {match: include("propertyNames"), 0: "member"},
                    {match: /\b([a-z][\w-]*)\s*(?=:)/, 1: "member"},
                    {match: /[:<>=]/, 0: "operator"},
                    {include: "numbers"},
                    {match: include("propertyValues"), 0: "type"}
                ]
            }
        ]
    ],

    contains: [
        // @规则（charset, import, namespace）
        {
            start: {match: /(@(?:charset|import|namespace))\b/, 1: "annotation"},
            end: {match: /;/},
            contains: [
                {include: "strings"},
                {include: "urlFunction"},
                {match: include("propertyValues"), 0: "type"}
            ]
        },

        // @media, @supports 等
        {
            start: {match: /(@(?:media|supports|document))\b/, 1: "annotation"},
            end: {match: /(?=\{)/},
            contains: [
                {include: "strings"},
                {match: /\b(and|or|not|only)\b/, 0: "keyword"},
                {match: include("propertyValues"), 0: "type"},
                {include: "mediaFeatures"}
            ]
        },

        // @keyframes, @font-face, @page 等
        {
            start: {match: /(@(?:keyframes|-webkit-keyframes|-moz-keyframes|font-face|page|counter-style|font-feature-values|property|layer))\b/, 1: "annotation"},
            end: {match: /(?=\{)/},
            contains: [
                {include: "strings"},
                {match: /\b[a-zA-Z][\w-]*/, 0: "funcName"}   // 自定义名称
            ]
        },

        // 标签选择器
        {match: include("htmlTags"), 0: "keyword"},

        // 通配符
        {match: /\*/, 0: "operator"},

        // ID 选择器
        {match: /#[a-zA-Z][\w-]*/, 0: "warning"},

        // 类选择器
        {match: /\.[a-zA-Z][\w-]*/, 0: "type"},

        // 伪类和伪元素
        {match: /::?[a-zA-Z][\w-]*/, 0: "contorKeyword"},

        // 属性选择器 [attr=val]
        {
            start: {match: /\[/},
            end: {match: /\]/},
            contains: [
                {match: /[~|^$*]?=/, 0: "operator"},
                {include: "strings"},
                {match: /\b[a-zA-Z][\w-]*/, 0: "member"}
            ]
        },

        // 选择器关系符
        {match: /[>+~]/, 0: "operator"},

        // !important
        {match: /!important\b/, 0: "annotation"},

        // 规则块 { }
        {
            start: {match: /\{/},
            end: {match: /\}/},
            contains: [
                // 注释
                {match: /(?s)\/\*.*?\*\//, 0: "comment"},

                // 嵌套 &
                {match: /&/, 0: "operator"},

                // CSS 自定义属性定义
                {match: /(--[\w-]+)\s*(?=:)/, 1: "member"},

                // 属性名
                {match: /\b([a-zA-Z][\w-]*)\s*(?=:)/, 1: "member"},
                {match: include("propertyNames") + /(?=\s*:)/, 0: "member"},

                // 属性值
                {
                    start: {match: /:/},
                    end: {match: /;|(?=\})/},
                    contains: [
                        {include: "urlFunction"},
                        {include: "varFunction"},
                        {include: "functions"},
                        {include: "strings"},
                        {include: "numbers"},
                        {match: include("propertyValues"), 0: "type"},
                        {match: /!important\b/, 0: "annotation"},
                        {match: /\//, 0: "operator"},
                        {match: /,/, 0: "operator"}
                    ]
                }
            ]
        },

        // 数字（如 nth-child 中的数字）
        {include: "numbers"}
    ],

    codeFormatter: #BUILT_IN_CSS_FORMATTER#,
    codeShrinker: #BUILT_IN_CSS_SHRINKER#
}
