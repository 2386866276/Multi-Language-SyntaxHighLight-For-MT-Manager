// ================================================
// Plain Text / Log / Crash Report Syntax Highlight
// 适用于：普通文本、日志文件、Minecraft 崩溃报告等
// 行数 ≥ 1000 的完整版
// ================================================

{
    name: ["Plain Text", ".txt", ".text", ".log", ".md", ".markdown", ".mc", ".crash", ".out"],
    ignoreCase: false,

    styles: [
        // 颜色定义
        "funcName"       #009999 #66e6ff,   // URL / 链接
        "operator"       #00009c #abc9ff,   // 符号、列表标记、分隔线
        "member"         #0066ad #bce0ff,   // 电子邮件、IP、MAC、UUID
        "method"         #0039e6 #57b3ff,   // 方法调用 / 堆栈帧方法名
        "annotation"     #cc5e00 #ffb373,   // 注解 / 标签
        "nodeReference"  #2e8c00 #63c259,   // 文件路径
        "comment"        #141414 #dddddd,   // 注释 / 分隔线
        "docComment"     #282666 #99b3cc,   // 文档注释风格
        "identifier"     #000000 #ffffff,   // 默认标识符
        "string"         #996b00 #ffeda1,   // 引号字符串
        "keyword"        #e62282 #ff7085,   // 错误 / 致命 / 异常
        "contorKeyword"  #bd1fcc #ff8ccc,   // 控制流 / 状态变更
        "number"         #008c47 #a1ffe0,   // 数字、日期、时间、十六进制
        "type"           #009933 #42ffc2,   // 成功 / 完成 / 正常
        "critical"       #cc2424 #c45959,   // TODO / FIXME / 待办 / 严重
        "warning"        #bf6308 #b89c7a,   // WARNING / 警告 / 注意
        "notice"         #3d8a17 #8fab82,   // NOTE / 提示 / 信息 / 调试
        "placeholder"    #ed9954 #ffbf66    // 占位符 / 转义
    ],

    // ===============================================
    // 可复用正则定义
    // ===============================================
    defines: [
        "timestampRegex": /(?:\d{4}[-\/]\d{1,2}[-\/]\d{1,2}[T ]\d{1,2}:\d{2}(?::\d{2}(?:\.\d+)?)?(?:Z|[+-]\d{2}:?\d{2})?)|\b\d{1,2}:\d{2}(?::\d{2})?(?:\.\d+)?\b/,
        "uuidRegex": /[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}/,
        "threadInfo": /\[[^\]]+\/\w+\]/,
        "stackFrame": /at\s+[\w.$]+\.[\w$]+\([\w.-]+:\d+\)/,
        "blockPos": /\(\s*-?\d+\.?\d*\s*,\s*-?\d+\.?\d*\s*,\s*-?\d+\.?\d*\s*\)/
    ],

    // ===============================================
    // 顶层匹配规则 (超过 1000 行展开)
    // ===============================================
    contains: [
        // ====================================================================
        // 1. 下载 / 安装 / 更新 / 卸载 (英文)
        // ====================================================================
        {match: /\bDOWNLOAD\b/, 0: "contorKeyword"},
        {match: /\bDOWNLOADING\b/, 0: "contorKeyword"},
        {match: /\bDOWNLOADED\b/, 0: "type"},
        {match: /\bINSTALL\b/, 0: "contorKeyword"},
        {match: /\bINSTALLING\b/, 0: "contorKeyword"},
        {match: /\bINSTALLED\b/, 0: "type"},
        {match: /\bUNINSTALL\b/, 0: "contorKeyword"},
        {match: /\bUNINSTALLING\b/, 0: "contorKeyword"},
        {match: /\bUNINSTALLED\b/, 0: "type"},
        {match: /\bUPDATE\b/, 0: "contorKeyword"},
        {match: /\bUPDATING\b/, 0: "contorKeyword"},
        {match: /\bUPDATED\b/, 0: "type"},
        {match: /\bUPGRADE\b/, 0: "contorKeyword"},
        {match: /\bUPGRADING\b/, 0: "contorKeyword"},
        {match: /\bUPGRADED\b/, 0: "type"},
        {match: /\bSETUP\b/, 0: "contorKeyword"},
        {match: /\bCONFIGURE\b/, 0: "contorKeyword"},
        {match: /\bCONFIGURING\b/, 0: "contorKeyword"},
        {match: /\bCONFIGURED\b/, 0: "type"},
        {match: /\bDEPLOY\b/, 0: "contorKeyword"},
        {match: /\bDEPLOYING\b/, 0: "contorKeyword"},
        {match: /\bDEPLOYED\b/, 0: "type"},
        {match: /\bEXTRACT\b/, 0: "contorKeyword"},
        {match: /\bEXTRACTING\b/, 0: "contorKeyword"},
        {match: /\bEXTRACTED\b/, 0: "type"},
        {match: /\bPATCH\b/, 0: "contorKeyword"},
        {match: /\bPATCHING\b/, 0: "contorKeyword"},
        {match: /\bPATCHED\b/, 0: "type"},
        {match: /\bINITIALIZE\b/, 0: "contorKeyword"},
        {match: /\bINITIALIZING\b/, 0: "contorKeyword"},
        {match: /\bINITIALIZED\b/, 0: "type"},

        // ====================================================================
        // 2. 下载 / 安装 / 更新 / 卸载 (中文)
