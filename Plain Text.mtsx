        // ====================================================================
        {match: /(?m)^[ \t]*[-*+] +/, 0: "operator"},
        {match: /(?m)^[ \t]*\d+\.[ \t]+/, 0: "operator"},
        {match: /(?m)^[ \t]*[-*_=]{3,}[ \t]*$/, 0: "comment"},
        {match: /(?m)^[ \t]*#.*$/, 0: "comment"},
        {match: /(?m)^[ \t]*\/\/.*$/, 0: "comment"},

        // ====================================================================
        // 35. 符号全集 (按 Unicode 块展开)
        // ====================================================================
        {match: /[\x21-\x2F\x3A-\x40\x5B-\x60\x7B-\x7E]/, 0: "operator"},
        {match: /[\u00A1-\u00BF]/, 0: "operator"},
        {match: /[\u2000-\u206F]/, 0: "operator"},
        {match: /[\u20A0-\u20CF]/, 0: "operator"},
        {match: /[\u2100-\u214F]/, 0: "operator"},
        {match: /[\u2190-\u21FF]/, 0: "operator"},
        {match: /[\u2200-\u22FF]/, 0: "operator"},
        {match: /[\u2300-\u23FF]/, 0: "operator"},
        {match: /[\u2500-\u257F]/, 0: "operator"},
        {match: /[\u2580-\u259F]/, 0: "operator"},
        {match: /[\u25A0-\u25FF]/, 0: "operator"},
        {match: /[\u2600-\u26FF]/, 0: "operator"},
        {match: /[\u2700-\u27BF]/, 0: "operator"},
        {match: /[\u2900-\u297F]/, 0: "operator"},
        {match: /[\u2B00-\u2BFF]/, 0: "operator"},
        {match: /[\u3000-\u303F]/, 0: "operator"},
        {match: /[\uFF01-\uFF0F\uFF1A-\uFF20\uFF3B-\uFF40\uFF5B-\uFF5E]/, 0: "operator"},
        {match: /[\uFFE0-\uFFEE]/, 0: "operator"},
        {match: /[\uD800-\uDBFF][\uDC00-\uDFFF]/, 0: "operator"},
        {match: /[\uFE50-\uFE6F]/, 0: "operator"},
        {match: /[\uFE30-\uFE4F]/, 0: "operator"},
        {match: /[\u2010-\u2027]/, 0: "operator"},
        {match: /[\u2030-\u205E]/, 0: "operator"}
    ]
}
